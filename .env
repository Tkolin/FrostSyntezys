# Переменные для docker-compose (можно менять под себя)

# --- Порты на хосте ---
BACKEND_PORT=8000      # Laravel + GraphQL  (фиксирован: фронтенд ходит на localhost:8000)
FRONTEND_PORT=3000     # React (CRA)
PMA_PORT=8080          # phpMyAdmin
DB_PORT=3306           # MySQL

# --- Адрес бэкенда для фронтенда ---
# На какой URL браузер шлёт GraphQL-запросы. Локально — localhost:8000.
# На проде укажите публичный адрес бэкенда, напр. https://api.example.com/graphql/
GRAPHQL_API_URL=http://localhost:8000/graphql/

# --- База данных ---
DB_DATABASE=backend
DB_PASSWORD=root

# --- Демо-данные и админ ---
# true — наполнить БД тестовыми данными из DatabaseSeeder при старте
DB_SEED=true
ADMIN_NAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=password
